# TradeForge site configuration — edit and re-run `node build.mjs`.

# Where the site is deployed (used for canonical URL, sitemap, Open Graph).
SITE_URL=https://bl4ckxr0sexd.github.io/TradeForge

# Installer download link — update this on every new release.
DOWNLOAD_URL=https://downloads.tradeforge.app/TradeForge-Setup.exe

# Search Console / Webmaster Tools verification tokens (optional).
GOOGLE_SITE_VERIFICATION=
BING_SITE_VERIFICATION=

# Ad platform tags (optional). Set these when your ad accounts are ready.
# When any ID below is set, the build injects the tag scripts, a GDPR consent
# banner (Consent Mode v2, denied by default), and download-click conversion
# events automatically.

# Google Ads tag ID, e.g. AW-123456789
GOOGLE_ADS_ID=
# Conversion label for the "download click" conversion action, e.g. AbC-D_efGhIjKlM
GOOGLE_ADS_CONVERSION_LABEL=
# Google Analytics 4 measurement ID (optional), e.g. G-XXXXXXXXXX
GA4_ID=
# Microsoft Advertising UET tag ID, e.g. 12345678
MICROSOFT_UET_ID=
